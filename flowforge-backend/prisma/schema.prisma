generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum UserStatus {
  ACTIVE
  INVITED
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  password  String?
  googleId  String?    @unique
  githubId  String?    @unique
  role      Role       @default(MEMBER)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  tasks     Task[]     @relation("AssignedTasks")
}

model Project {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  priority    Priority  @default(MEDIUM)
  status      String    @default("IN_PROGRESS") // "TODO", "IN_PROGRESS", "DONE"
  progress    Int       @default(0) // 0 to 100
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  tasks       Task[]
}

model Task {
  id         String     @id @default(uuid())
  title      String
  priority   Priority   @default(MEDIUM)
  projectId  String?
  project    Project?   @relation(fields: [projectId], references: [id])
  createdAt  DateTime   @default(now())
  assigneeId String?
  assignee   User?      @relation("AssignedTasks", fields: [assigneeId], references: [id])
  status     TaskStatus @default(TODO)
}

model Activity {
  id        String   @id @default(uuid())
  userId    String
  userEmail String
  action    String   // CREATED, MOVED, DELETED
  details   String
  timestamp DateTime @default(now())
}
