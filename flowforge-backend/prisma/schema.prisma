generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}
enum TaskStatus{
  TODO
  IN_PROGRESS
  DONE
}
enum Priority{
  LOW
  MEDIUM
  HIGH
  
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
}


model Task {
  id         String      @id @default(uuid())
  title      String
  status     TaskStatus  @default(TODO)
  priority   Priority    @default(MEDIUM)

  assigneeId String?
  projectId  String

  createdAt  DateTime    @default(now())
}